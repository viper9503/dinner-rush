{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "Ingestion rate (orders/sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (result) (rate(ingestion_orders_total[1m]))", "legendFormat": "{{result}}" }
      ]
    },
    {
      "title": "Transitions applied/sec (by target state)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (to) (rate(orchestrator_transitions_total[1m]))", "legendFormat": "{{to}}" }
      ]
    },
    {
      "title": "In-flight advance handlers",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [ { "refId": "A", "expr": "sum(orchestrator_inflight)" } ]
    },
    {
      "title": "Broker retries (total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [ { "refId": "A", "expr": "sum(orchestrator_broker_retries_total)" } ]
    },
    {
      "title": "DLQ parked (total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(orchestrator_dlq_total)" } ]
    },
    {
      "title": "Delivered/sec",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "targets": [ { "refId": "A", "expr": "sum(rate(orchestrator_transitions_total{to=\"delivered\"}[1m]))" } ]
    },
    {
      "title": "Downstream requests/sec (by result)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (job, result) (rate(downstream_requests_total[1m]))", "legendFormat": "{{job}} {{result}}" }
      ]
    },
    {
      "title": "Downstream avg latency (p90, sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.9, sum by (job, le) (rate(downstream_latency_seconds_bucket[1m])))", "legendFormat": "{{job}}" }
      ]
    }
  ],
  "refresh": "5s",
