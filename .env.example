# Dinner Rush - environment tunables
# Copy to .env to override. docker-compose.yml ships with these as defaults.

# ---- Infra ----
POSTGRES_USER=dinner
POSTGRES_PASSWORD=dinner
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

RABBITMQ_USER=dinner
RABBITMQ_PASSWORD=dinner
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

REDIS_HOST=redis
REDIS_PORT=6379

# ---- Orchestrator resilience knobs ----
# Per-attempt HTTP timeout to a downstream (seconds)
DOWNSTREAM_TIMEOUT_SECONDS=3.0
# In-process retry attempts per stage before the message is delayed/redelivered
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_BASE_SECONDS=0.2
HTTP_BACKOFF_MAX_SECONDS=2.0
# Broker-level redelivery cap before a message goes to the DLQ
BROKER_MAX_ATTEMPTS=6
# Delay (ms) a failed message waits in the retry queue before being redelivered
RETRY_QUEUE_TTL_MS=5000
# Circuit breaker: consecutive failures to open, seconds to stay open before half-open
CIRCUIT_FAIL_THRESHOLD=5
CIRCUIT_OPEN_SECONDS=10
# Simulated kitchen cook time (preparing -> ready) think time
COOK_SECONDS=2.0
# Simulated delivery leg (out_for_delivery -> delivered) think time
DELIVERY_DRIVE_SECONDS=2.0
# Fraction of early-stage orders the simulated customer cancels (0 disables)
CANCEL_RATE=0.0
# Unacked advance commands the orchestrator processes concurrently (broker prefetch)
ORCH_PREFETCH=64
# How often (seconds) to auto-drain DLQ-parked orders back onto the pipeline once
# the downstreams report healthy again (automatic recovery after a forced outage)
DLQ_REPLAY_INTERVAL_SECONDS=15

# ---- restaurant-svc flakiness (tunable at runtime via /control) ----
RESTAURANT_BASE_LATENCY_MS=150
RESTAURANT_JITTER_MS=400
RESTAURANT_FAILURE_RATE=0.12
RESTAURANT_TIMEOUT_RATE=0.04
RESTAURANT_RATE_LIMIT_RPS=25
# Random fall-over windows: probability per check and duration
RESTAURANT_OUTAGE_PROB=0.0
RESTAURANT_OUTAGE_SECONDS=20

# ---- courier-svc flakiness ----
COURIER_BASE_LATENCY_MS=200
COURIER_JITTER_MS=500
COURIER_FAILURE_RATE=0.12
COURIER_TIMEOUT_RATE=0.04
COURIER_RATE_LIMIT_RPS=25
COURIER_OUTAGE_PROB=0.0
COURIER_OUTAGE_SECONDS=20

# ---- load-gen ----
# Baseline steady orders per second on startup
LOADGEN_BASELINE_RPS=3
# Dinner-rush target when triggered
LOADGEN_RUSH_RPS=80
# Seconds to ramp from baseline to rush
LOADGEN_RUSH_RAMP_SECONDS=5
# Autostart the baseline drip on boot (1/0)
LOADGEN_AUTOSTART=1
# Fraction of orders re-sent with a prior idempotency key, to exercise dedup (0 disables)
LOADGEN_DUP_RATE=0.0

# ---- dashboard ----
# How often the dashboard-api pushes a snapshot to browsers (ms)
DASHBOARD_PUSH_INTERVAL_MS=1000
